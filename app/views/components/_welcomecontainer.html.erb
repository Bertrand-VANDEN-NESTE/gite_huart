<div class="welcome-hero-image" data-controller="zoom-background">
  <%= image_tag "house/accueil2.jpg",
      class: "zoom-background",
      data: { "zoom-background-target": "image" } %>
</div>

<section class="welcome-intro">

  <div class="welcome-intro-inner">

    <span class="welcome-subtitle">
      Chambres d’hôtes en Anjou
    </span>

    <h1>Chambre d’hôtes en Anjou – L’Entre-Deux-Pommes</h1>

    <div class="welcome-divider"></div>

    <p class="welcome-tagline">
      Un lieu authentique entre nature et patrimoine,
      où charme, calme et douceur de vivre se rencontrent.
      Chambre d’hôtes située à Huillé-Lézigné, proche d’Angers, idéale pour un séjour en couple ou en famille avec piscine.
    </p>

    <%= link_to "Découvrir le site",
      home_path,
      class: "welcome-button",
      data: { turbo: true } %>

  </div>

</section>
