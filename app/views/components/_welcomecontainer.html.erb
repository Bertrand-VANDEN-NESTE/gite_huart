<div class="welcome-hero" data-controller="zoom-background">

  <!-- IMAGE -->
  <div class="welcome-image">
    <%= image_tag "house/accueil16.jpg",
      class: "zoom-background",
      data: { "zoom-background-target": "image" } %>
    <div class="welcome-overlay"></div>
  </div>

  <!-- CONTENU -->
  <div class="welcome-content">

    <span class="welcome-subtitle">
      Maison d’hôtes en Anjou
    </span>

    <h1>L’Entre Deux Pommes</h1>

    <div class="welcome-divider"></div>

    <p class="welcome-tagline">
      Un lieu authentique entre nature et patrimoine
    </p>

    <%= link_to "Découvrir le site",
      home_path,
      class: "welcome-button",
      data: { turbo: true } %>

  </div>

</div>
