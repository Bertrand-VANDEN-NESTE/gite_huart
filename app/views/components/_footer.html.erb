<footer class="footer" data-controller="reveal">
  <div class="footer-line"></div>

  <div class="footer-inner">

    <!-- LOGO -->
    <div class="footer-logo">
      <%= image_tag "logo.png",
          alt: "Logo L'Entre Deux Pommes",
          class: "footer-logo-img" %>
    </div>

    <!-- CONTACT -->
    <div class="footer-contact">
      <a href="mailto:lentredeuxpommes@gmail.com">
        <span class="icon">✉</span>
        lentredeuxpommes@gmail.com
      </a>

      <span class="separator">•</span>

      <a href="tel:+33670834578">
        <span class="icon">☎</span>
        +33 (0)6 70 83 45 78
      </a>
    </div>

    <!-- ADRESSE -->
    <div class="footer-address">
      608 route de la Guiberdière — Lézigné, France
    </div>

    <!-- LIENS -->
    <div class="footer-links">
      <%= link_to 'Mentions légales', legal_path %>
      <span class="separator">•</span>
      <%= link_to 'Politique de confidentialité', policy_path %>
    </div>

    <!-- COPYRIGHT -->
    <div class="footer-bottom">
      © <%= Time.current.year %> L’Entre Deux Pommes — Tous droits réservés
    </div>

  </div>
</footer>
