<div class="navbar-wrapper"
     data-controller="burger navbar"
     data-navbar-target="wrapper">

  <nav class="navbar">

    <!-- LOGO -->
    <div class="navbar-left">
      <%= link_to root_path, class: "navbar-logo" do %>
        <%= image_tag "logo.png", alt: "L'Entre Deux Pommes" %>
      <% end %>
    </div>

    <!-- BURGER -->
    <button
      class="burger"
      data-action="click->burger#toggle"
      data-burger-target="button"
      aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- MENU -->
    <ul class="navbar-menu" data-burger-target="menu">

      <li>
        <%= link_to "Bienvenue", root_path,
          class: "navbar-link #{'active' if current_page?(root_path)}",
          data: { action: "click->burger#close" } %>
      </li>

      <li>
        <%= link_to "Accueil", home_path,
          class: "navbar-link #{'active' if current_page?(home_path)}",
          data: { action: "click->burger#close" } %>
      </li>

      <li>
        <%= link_to "Nos Chambres", rooms_path,
          class: "navbar-link #{'active' if current_page?(rooms_path)}",
          data: { action: "click->burger#close" } %>
      </li>

      <li>
        <%= link_to "Activités", activities_path,
          class: "navbar-link #{'active' if current_page?(activities_path)}",
          data: { action: "click->burger#close" } %>
      </li>

      <li>
        <%= link_to "Contact", contact_path,
          class: "navbar-link navbar-link--cta #{'active' if current_page?(contact_path)}",
          data: { action: "click->burger#close" } %>
      </li>

    </ul>

  </nav>
</div>
