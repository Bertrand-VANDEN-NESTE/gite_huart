<%= render "components/navbar" %>

<!-- INTRO -->

<section class="contact-intro" data-controller="reveal">
  <div class="contact-intro-inner">

    <span class="contact-subtitle">Entrer en contact</span>
    <h1>Nous Contacter</h1>
    <div class="contact-divider"></div>

    <p>
      Une question, une demande particulière ou une réservation ?
      Nous serons ravis d’échanger avec vous et de vous accompagner
      dans l’organisation de votre séjour.
    </p>

  </div>
</section>


<!-- SECTION PRINCIPALE -->

<section class="contact-section">

  <div class="contact-container">

    <!-- INFOS -->
    <div class="contact-left" data-controller="reveal">

      <div class="contact-item">
        <div class="contact-icon">📍</div>
        <div>
          <h4>Adresse</h4>
          <p>
            608 route de la Guiberdière<br>
            Lézigné, France
          </p>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">📞</div>
        <div>
          <h4>Téléphone</h4>
          <p>
            <a data-controller="contact-protect"
               data-action="click->contact-protect#reveal"
               data-contact-protect-phone-value="+33677320728">
              Afficher le téléphone
            </a>
          </p>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">✉</div>
        <div>
          <h4>Email</h4>
          <p>
            <a data-controller="contact-protect"
               data-action="click->contact-protect#reveal"
               data-contact-protect-user-value="lentredeuxpommes"
               data-contact-protect-domain-value="gmail.com">
              Afficher l’email
            </a>
          </p>
        </div>
      </div>

    </div>


    <!-- FORMULAIRE -->
    <div class="contact-right" data-controller="reveal">

      <div class="contact-card">
        <h3>Envoyer un message</h3>

        <%= form_with url: contact_path, method: :post, local: true do |f| %>

          <div class="form-group">
            <%= f.text_field :name, required: true %>
            <%= f.label :name, "Nom complet" %>
          </div>

          <div class="form-group">
            <%= f.email_field :email, required: true %>
            <%= f.label :email, "Email" %>
          </div>

          <div class="form-group">
            <%= f.text_area :message, rows: 4, required: true %>
            <%= f.label :message, "Votre message" %>
          </div>

          <!-- Honeypot -->
          <div style="display:none;">
            <%= f.text_field :nickname, autocomplete: "off" %>
          </div>

          <%= f.submit "Envoyer", class: "btn-contact" %>

        <% end %>

      </div>

    </div>

  </div>

</section>


<!-- CARTE PREMIUM -->

<section class="contact-map">
  <iframe
    src="https://www.google.com/maps?q=608+route+de+la+Guiberdière,+Lézigné,+France&output=embed"
    loading="lazy"
    allowfullscreen>
  </iframe>
</section>

<%= render "components/footer" %>
