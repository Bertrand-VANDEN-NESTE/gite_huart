<%= render "components/navbar" %>

<section class="contact-section">

  <div class="contact-container">

    <!-- LEFT SIDE -->
    <div class="contact-left">
      <h2 class="contact-title">Nous contacter</h2>
      <p class="contact-intro">
        Une question, une demande particulière ou une réservation ?
        Nous serons ravis d’échanger avec vous.
      </p>

      <div class="contact-info">

        <div class="contact-item">
          <div class="contact-icon">📍</div>
          <div>
            <h4>Adresse</h4>
            <p>608 route de la Guiberdière<br>Lézigné, France</p>
          </div>
        </div>

        <!-- 📞 Téléphone protégé -->
        <div class="contact-item">
          <div class="contact-icon">📞</div>
          <div>
            <h4>Téléphone</h4>
            <p>
              <a data-controller="contact-protect"
                data-action="click->contact-protect#reveal"
                data-contact-protect-phone-value="+33677320728">
                Afficher le téléphone
              </a>
            </p>
          </div>
        </div>

        <!-- ✉ Email protégé -->
        <div class="contact-item">
          <div class="contact-icon">✉</div>
          <div>
            <h4>Email</h4>
            <p>
              <a data-controller="contact-protect"
                data-action="click->contact-protect#reveal"
                data-contact-protect-user-value="lentredeuxpommes"
                data-contact-protect-domain-value="gmail.com">
                Afficher l’email
              </a>
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- RIGHT SIDE -->
    <div class="contact-right">

      <div class="contact-card">
        <h3>Envoyer un message</h3>

        <%= form_with url: contact_path, method: :post, local: true do |f| %>

          <div class="form-group">
            <%= f.text_field :name, required: true %>
            <%= f.label :name, "Nom complet" %>
          </div>

          <div class="form-group">
            <%= f.email_field :email, required: true %>
            <%= f.label :email, "Email" %>
          </div>

          <div class="form-group">
            <%= f.text_area :message, rows: 4, required: true %>
            <%= f.label :message, "Votre message" %>
          </div>

          <!-- Honeypot anti-spam -->
          <div style="display:none;">
            <%= f.label :nickname %>
            <%= f.text_field :nickname, autocomplete: "off" %>
          </div>

          <%= f.submit "Envoyer", class: "btn-contact" %>

        <% end %>
      </div>

    </div>

  </div>

  <!-- GOOGLE MAP -->
  <div class="contact-map">
    <iframe
      src="https://www.google.com/maps/place/608+La+Guiberdi%C3%A8re,+49430+Huill%C3%A9-L%C3%A9zign%C3%A9/@47.6295498,-0.3127686,17z/data=!3m1!4b1!4m6!3m5!1s0x480812c19c5183a9:0xcfe21c4f57e534f8!8m2!3d47.6295498!4d-0.3101937!16s%2Fg%2F11c1671_lm?entry=ttu&g_ep=EgoyMDI2MDMwMS4xIKXMDSoASAFQAw%3D%3D"
      loading="lazy">
    </iframe>
  </div>

</section>

<%= render "components/footer" %>
