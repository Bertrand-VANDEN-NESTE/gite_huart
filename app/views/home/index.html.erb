<%= render "components/navbar" %>
<%= render "components/backgroundheader" %>

<section class="home-intro" data-controller="reveal">

  <div class="home-intro-inner">

    <!-- MOSAÏQUE -->
    <div class="home-gallery">
      <% @home_photos.each do |photo| %>
        <% photo.image_paths.first(6).each do |image| %>
          <div class="gallery-item">
            <%= image_tag image,
              data: {
                action: "click->lightbox#open",
                lightbox_image_url: asset_path(image)
              } %>
          </div>
        <% end %>
      <% end %>
    </div>

    <!-- TEXTE -->
    <div class="home-text">

      <span class="home-subtitle">Maison d’hôtes de charme</span>

      <h2>L’Entre Deux Pommes</h2>

      <div class="home-divider"></div>

      <p>
        Il y a une dizaine d’années, nous avons eu un véritable coup de cœur pour cette
        demeure du XVIᵉ siècle et son histoire.
      </p>

      <p>
        Nos chambres sont pensées comme nous aimons les trouver en voyage :
        lumineuses, spacieuses, propices au cocooning.
      </p>

      <p>
        Entourée de vergers, notre maison offre un environnement paisible,
        idéal pour se ressourcer et découvrir l’Anjou.
      </p>

      <%= link_to "Découvrir nos chambres", rooms_path, class: "home-button" %>

    </div>

  </div>

</section>

<!-- Lightbox -->
<div class="lightbox hidden" data-controller="lightbox" data-action="click->lightbox#close">
  <img class="lightbox-image" data-lightbox-target="image">
  <button class="lightbox-close">×</button>
</div>

<%= render "components/footer" %>
