<%= render "components/navbar" %>

<!-- INTRO -->

<section class="rooms-intro" data-controller="reveal">
  <div class="rooms-text">
    <span class="rooms-subtitle">Séjourner à L’Entre Deux Pommes</span>
    <h1>Nos Chambres</h1>
    <div class="rooms-divider"></div>

    <p>
      Spacieuses, lumineuses et pensées pour le confort,
      nos chambres d’hôtes allient charme de l’ancien et élégance contemporaine.
    </p>

    <p>
      Chaque suite dispose d’un espace généreux,
      idéal pour un séjour à deux ou en famille,
      dans un cadre paisible au cœur de l’Anjou.
    </p>
  </div>
</section>


<!-- LISTE DES CHAMBRES -->

<section class="rooms-wrapper">

  <% @rooms.each_with_index do |room, index| %>

    <div class="room-row <%= 'reverse' if index.odd? %>"
         data-controller="reveal">

      <!-- MOSAÏQUE IMAGES -->
      <div class="room-gallery">

        <% room.image_paths.first(4).each_with_index do |src, i| %>
          <div class="gallery-item <%= 'large' if i == 0 %>">
            <%= image_tag src,
                  alt: room.title,
                  loading: "lazy",
                  data: {
                    action: "click->lightbox#open",
                    lightbox_image_url: asset_path(src)
                  } %>
          </div>
        <% end %>

      </div>

      <!-- TEXTE -->
      <div class="room-content">
        <h2><%= room.title %></h2>

        <div class="room-meta">
          <p><strong>Taille</strong><span><%= room.size %></span></p>
          <p><strong>Capacité</strong><span><%= room.capacity %> personnes</span></p>
          <p><strong>Lits</strong><span><%= room.bed_count %></span></p>
          <p><strong>Prix</strong><span><%= number_to_currency(room.price, unit: "€") %> / nuit</span></p>
        </div>

        <p class="features"><%= room.features %></p>

        <a href="/contact" class="room-button">
          Réserver cette chambre
        </a>
      </div>

    </div>

  <% end %>

</section>

<%= render "components/footer" %>
